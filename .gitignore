# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
token
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# Project assets (large / binary — use Google Drive for these)
data/
weights/
*.zip
# Phase 1.A hand-corrected Roboflow export (~2.5 MB; committed for reproducibility).
!datasets/handcorrected_desktop_test/visclick3.yolov8.zip
*.tar
*.tar.gz
*.7z
*.onnx
*.pt
*.pth
*.ckpt
# Allow the deployable ONNX model so a fresh clone can run the bot.
# Notebook 07_export_onnx.ipynb writes it.
!weights/
!weights/visclick.onnx
!weights/.gitkeep

# Secrets
.env
.env.*
!.env.example

# OS / editor
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/

# Local data dumps (optional)
*.log
screenshots/
probe.png
.cache/

# Editable install (pip install -e) — do not commit
**/*.egg-info/

# Local detector benchmark CSV (e.g. scripts/test_detector.py)
tables/

# Local backup when resolving pull vs untracked baseline CSV
reports/tables/*.local.backup.csv

# Phase 1.C: per-run captures and user-captured templates are local artefacts.
# Their containing directories ARE tracked (via .gitkeep / README.md) so the
# layout is reproducible; the PNGs themselves are not.
samples/test_screenshots/*.png
samples/templates/*.png
!samples/test_screenshots/.gitkeep
!samples/templates/README.md
# Per-task baseline overlays generated by scripts/run_baselines.py
reports/figures/baselines/*.png
