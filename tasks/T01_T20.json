    "target_uia_role":"(pywinauto baseline) optional UIA control type (Button, Edit, MenuItem, ListItem...) for disambiguation.",
    "is_negative":    "true => the bot SHOULD refuse to click; success means returning a graceful failure, not a wrong click."
  },

